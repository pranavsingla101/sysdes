model TaskRun {
  id        String   @id @default(cuid())
  runId     String   @unique @map("run_id")
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([runId])
  @@index([userId, projectId])
  @@map("task_runs")
}
